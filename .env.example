# ai-v-models configuration via environment variables
# Copy to .env and fill in as needed

# Docker Compose — external (host) ports mapped into containers
AIVM_HOST_PROXY_PORT=4000
AIVM_HOST_WEB_PORT=5173
AIVM_HOST_MOCK_PORT=11434

# Public URLs shown in the startup banner (auto-set by docker-compose from host ports above)
# AIVM_URL=http://localhost:4000
# AIVM_WEB_URL=http://localhost:5173

# Server
AIVM_HOST=0.0.0.0
AIVM_PORT=4000

# Data directory (default: ~/.aivm)
# AIVM_DATA_DIR=/path/to/data

# Log level: trace | debug | info | warn | error | fatal
AIVM_LOG_LEVEL=info

# Log format: json | pretty
AIVM_LOG_FORMAT=json

# TLS (optional)
# AIVM_TLS_CERT=/path/to/cert.pem
# AIVM_TLS_KEY=/path/to/key.pem

# Admin initial setup (only used on first run to create admin user)
# AIVM_ADMIN_USER=admin
# AIVM_ADMIN_PASSWORD=admin

# Passkeys / WebAuthn (optional; auto-detected from Host header in dev)
# AIVM_WEBAUTHN_RP_ID=localhost
# AIVM_WEBAUTHN_ORIGINS=http://localhost:4000,http://localhost:5173

# CORS allowed origins (comma-separated, * for all)
# When using Docker Compose with custom host ports, include both URLs, e.g.:
# AIVM_CORS_ORIGINS=http://localhost:4000,http://localhost:5173
AIVM_CORS_ORIGINS=http://localhost:4000,http://localhost:5173

# Metrics
AIVM_METRICS_ENABLED=true
# AIVM_OTEL_ENDPOINT=http://localhost:4318

# Health check interval in seconds
AIVM_HEALTH_CHECK_INTERVAL=30
