# ai-v-models configuration via environment variables
# Copy to .env and fill in as needed

# Server
AVM_HOST=0.0.0.0
AVM_PORT=4000

# Data directory (default: ~/.ai-reverse-proxy)
# AVM_DATA_DIR=/path/to/data

# Log level: trace | debug | info | warn | error | fatal
AVM_LOG_LEVEL=info

# Log format: json | pretty
AVM_LOG_FORMAT=json

# TLS (optional)
# AVM_TLS_CERT=/path/to/cert.pem
# AVM_TLS_KEY=/path/to/key.pem

# Admin initial setup (only used on first run to create admin user)
# AVM_ADMIN_USER=admin
# AVM_ADMIN_PASSWORD=admin

# Passkeys / WebAuthn (optional; auto-detected from Host header in dev)
# AVM_WEBAUTHN_RP_ID=localhost
# AVM_WEBAUTHN_ORIGINS=http://localhost:4000,http://localhost:5173

# CORS allowed origins (comma-separated, * for all)
AVM_CORS_ORIGINS=http://localhost:5173

# Metrics
AVM_METRICS_ENABLED=true
# AVM_OTEL_ENDPOINT=http://localhost:4318

# Health check interval in seconds
AVM_HEALTH_CHECK_INTERVAL=30
