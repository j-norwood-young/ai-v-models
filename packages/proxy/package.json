{
  "name": "@ai-v-models/proxy",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./balancer": {
      "import": "./dist/balancer.js",
      "types": "./dist/balancer.d.ts"
    },
    "./app": {
      "import": "./dist/app.js",
      "types": "./dist/app.d.ts"
    },
    "./key-auth": {
      "import": "./dist/key-auth.js",
      "types": "./dist/key-auth.d.ts"
    },
    "./sse": {
      "import": "./dist/sse.js",
      "types": "./dist/sse.d.ts"
    }
  },
  "bin": {
    "avm-proxy": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "AVM_DEV=1 tsx watch src/index.ts",
    "start:watch": "AVM_DEV=1 node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint src",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@ai-v-models/core": "workspace:*",
    "@ai-v-models/hooks-sdk": "workspace:*",
    "@ai-v-models/plugin-sdk": "workspace:*",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.3",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.1",
    "@node-rs/argon2": "^2.0.0",
    "@simplewebauthn/server": "^13.3.0",
    "drizzle-orm": "^0.44.1",
    "esbuild": "^0.28.1",
    "fastify": "^5.4.0",
    "isolated-vm": "^7.0.0",
    "ms": "^2.1.3",
    "nanoid": "^5.1.5",
    "otplib": "^12.0.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "pino-roll": "^1.0.0",
    "prom-client": "^15.1.3",
    "undici": "^7.10.0"
  },
  "devDependencies": {
    "@types/ms": "^0.7.34",
    "@types/node": "^22.15.30",
    "tsx": "^4.22.4",
    "typescript": "^5.8.3",
    "vitest": "^3.2.3"
  }
}
