# Web UI dev settings
# Leave PUBLIC_API_URL unset in dev — Vite proxies /api to the proxy on :4001.
# Set PUBLIC_API_URL when the management API runs on a different host than the UI.
# PUBLIC_API_URL=http://localhost:4000
#
# Base URL for OpenAI-compatible /v1 inference (shown in Connect dialogs).
# Defaults to http://localhost:4001 in dev and the current origin in production.
# PUBLIC_PROXY_URL=http://localhost:4000
